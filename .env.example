# --- Google AI Studio (Default) ---
# Your primary Gemini API key
GEMINI_API_KEY=your_api_key_here

# --- Gemini Pro Specific Key (Optional) ---
# If provided, this key will be used specifically for gemini-3.1-pro-preview
GEMINI_PRO_API_KEY=your_pro_api_key_here

# --- Vertex AI Configuration (Optional) ---
# If both GCP_PROJECT and GCP_LOCATION are provided, Vertex AI will be used instead of AI Studio.
# Note: Vertex AI uses Application Default Credentials (ADC) or OAuth tokens.
GCP_PROJECT=your_gcp_project_id
GCP_LOCATION=europe-west3

# --- Nextcloud Integration ---
NEXTCLOUD_URL=https://your-nextcloud-instance.com
NEXTCLOUD_USER=your_username
NEXTCLOUD_PASSWORD=your_app_password
NEXTCLOUD_ROOT_FOLDER=FAQ-Bot-Project
WEBHOOK_SECRET=your_webhook_secret